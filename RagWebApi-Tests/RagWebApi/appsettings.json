{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=${DBSERVER};Database=${DATABASE};TrustServerCertificate=True;Encrypt=False;Trusted_Connection=True"
  },

  "Keys": {
    "JinaKey": "${JinaKey}",
    "OpenRouterApiKey": "${OpenRouterKey}",
    "CloudFlareKey": "${CloudFlareKey}"
  }
}
